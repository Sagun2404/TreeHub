{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://treehub.dev/schemas/tree-schema.json",
  "title": "TreeHub PageIndex Tree",
  "description": "Schema for TreeHub tree.json files containing hierarchical PageIndex data.",
  "type": "object",
  "required": ["meta", "tree"],
  "properties": {
    "meta": {
      "type": "object",
      "required": [
        "platform",
        "version",
        "indexed_at",
        "source_url",
        "tree_hash",
        "pages_count"
      ],
      "properties": {
        "platform": {
          "type": "string",
          "description": "Platform identifier (lowercase, hyphen-separated).",
          "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
        },
        "version": {
          "type": "string",
          "description": "Semantic version or date-based version string."
        },
        "snapshot_date": {
          "type": "string",
          "format": "date",
          "description": "ISO 8601 date of the snapshot."
        },
        "indexed_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of when indexing completed."
        },
        "source_url": {
          "type": "string",
          "format": "uri",
          "description": "URL of the source llms.txt or documentation root."
        },
        "tree_hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$",
          "description": "SHA-256 hash of the tree content."
        },
        "llms_txt_hash": {
          "type": ["string", "null"],
          "pattern": "^sha256:[a-f0-9]{64}$",
          "description": "SHA-256 hash of the source llms.txt."
        },
        "pages_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of pages indexed."
        },
        "tokens_indexed": {
          "type": "integer",
          "minimum": 0,
          "description": "Total tokens processed during indexing."
        },
        "indexer_version": {
          "type": "string",
          "description": "Version of the indexer used."
        },
        "indexed_by": {
          "type": "string",
          "description": "Identifier of the entity that performed indexing."
        },
        "build_log_url": {
          "type": ["string", "null"],
          "format": "uri",
          "description": "URL to the CI build log."
        }
      }
    },
    "tree": {
      "type": "object",
      "required": ["root"],
      "properties": {
        "root": {
          "$ref": "#/definitions/TreeNode"
        }
      }
    }
  },
  "definitions": {
    "TreeNode": {
      "type": "object",
      "required": ["id", "title", "summary", "children"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for this node within the tree."
        },
        "title": {
          "type": "string",
          "description": "Human-readable title of the documentation section."
        },
        "summary": {
          "type": "string",
          "description": "LLM-generated summary of the section content."
        },
        "content_hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]+$",
          "description": "SHA-256 hash of the section content."
        },
        "relationships": {
          "type": "object",
          "properties": {
            "related": {
              "type": "array",
              "items": { "type": "string" },
              "description": "IDs of related nodes."
            },
            "next_page": {
              "type": ["string", "null"],
              "description": "ID of the next page in reading order."
            },
            "parent": {
              "type": ["string", "null"],
              "description": "ID of the parent node."
            }
          }
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/TreeNode"
          },
          "description": "Child nodes in the hierarchy."
        }
      }
    }
  }
}
